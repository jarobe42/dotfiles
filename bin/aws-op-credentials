#!/usr/bin/env bash
# aws-op-credentials — fetch AWS credentials from 1Password for use as
# an AWS credential_process.
#
# Usage in ~/.config/aws/config:
#   [profile my-profile]
#   credential_process = aws-op-credentials "My 1Password Item Name"
#
# The 1Password item must have fields labelled exactly:
#   access_key_id
#   secret_access_key
#   session_token  (optional — for temporary credentials / assume-role)
#
# Output is the JSON format required by the AWS credential_process spec:
#   https://docs.aws.amazon.com/cli/latest/userguide/cli-configure-sourcing-external.html

set -euo pipefail

ITEM="${1:-}"

if [[ -z "$ITEM" ]]; then
  echo "Usage: aws-op-credentials <1password-item-name>" >&2
  exit 1
fi

if ! command -v op &>/dev/null; then
  echo "Error: 1Password CLI (op) not found in PATH" >&2
  exit 1
fi

if ! command -v jq &>/dev/null; then
  echo "Error: jq not found in PATH" >&2
  exit 1
fi

# Fetch item from 1Password and transform to AWS credential_process format.
# Handles optional session_token field gracefully.
op item get "$ITEM" --format json | jq '
  ( .fields // [] | map({(.label): .value}) | add ) as $f |
  {
    Version: 1,
    AccessKeyId:     ($f.access_key_id     // error("field access_key_id not found")),
    SecretAccessKey: ($f.secret_access_key // error("field secret_access_key not found"))
  }
  + if $f.session_token then { SessionToken: $f.session_token } else {} end
'
