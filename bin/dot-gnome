#!/usr/bin/env bash
# Description: First-run setup for GNOME desktop

set -Eeuo pipefail
source "$DOTFILES/bin/lib/common.sh"
command_name=$(basename "${BASH_SOURCE[0]}")

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_cmd "$command_name") $(fmt_value "[options] <command>")

  First-run setup for the GNOME desktop environment.

$(fmt_key "Commands:")
    setup         Run all first-run setup steps
    keybindings   Set GNOME custom keybindings (run inside a GNOME session)
    dirs          Create XDG user directories (Documents, Downloads, etc.)
EOF
}

cmd_dirs() {
  fmt_title_underline "Creating XDG user directories"

  if command -v xdg-user-dirs-update &>/dev/null; then
    xdg-user-dirs-update
    log_success "XDG user dirs created"
  else
    log_warning "xdg-user-dirs not found — install it first"
  fi
}

# Set GNOME custom keybindings. Must be called inside a running GNOME session.
# Invoked automatically on first login via the autostart entry written by cmd_setup.
cmd_keybindings() {
  fmt_title_underline "GNOME keybindings"

  local kb_path='/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/'

  # Skip if already set
  if gsettings get "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:${kb_path}" \
       binding 2>/dev/null | grep -q '<Super>d'; then
    log_info "Fuzzel keybinding already set"
  else
    gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings \
      "['${kb_path}']"
    gsettings set "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:${kb_path}" \
      name 'Launcher'
    gsettings set "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:${kb_path}" \
      command 'fuzzel'
    gsettings set "org.gnome.settings-daemon.plugins.media-keys.custom-keybinding:${kb_path}" \
      binding '<Super>d'
    log_success "Fuzzel launcher bound to Meta+D"
  fi

  # Self-remove: this autostart entry is one-shot
  rm -f "$HOME/.config/autostart/dot-gnome-keybindings.desktop"
}

cmd_setup() {
  fmt_title_underline "GNOME first-run setup"

  cmd_dirs

  # Enable GDM (display manager)
  if systemctl is-enabled gdm &>/dev/null; then
    log_info "GDM already enabled"
  else
    log_info "Enabling GDM..."
    sudo systemctl enable gdm
    log_success "GDM enabled"
  fi

  # Verify gnome-shell is present
  if command -v gnome-shell &>/dev/null; then
    log_success "gnome-shell found: $(gnome-shell --version)"
  else
    log_warning "gnome-shell not found — was the gnome package installed?"
  fi

  # Drop a one-shot autostart to apply GNOME keybindings on first login.
  # gsettings requires a running GNOME session, so we can't call it here.
  mkdir -p "$HOME/.config/autostart"
  cat > "$HOME/.config/autostart/dot-gnome-keybindings.desktop" <<DESKTOP
[Desktop Entry]
Type=Application
Name=Dotfiles GNOME keybindings (one-shot)
Exec=bash -c 'DOTFILES=${DOTFILES} PATH=${DOTFILES}/bin:\$PATH dot-gnome keybindings'
X-GNOME-Autostart-enabled=true
X-GNOME-Autostart-Delay=3
NoDisplay=true
Comment=Set GNOME custom keybindings on first login, then removes itself
DESKTOP
  log_success "Keybinding setup queued for first login (Meta+D → fuzzel)"

  echo -e
  log_success "GNOME setup done"
  log_info ""
  log_info "Manual step:"
  log_info "  Log out and select 'GNOME' from the display manager (GDM)"
}

main() {
  local subcmd="${1:-setup}"
  shift || true

  case "$subcmd" in
  setup)       cmd_setup ;;
  keybindings) cmd_keybindings ;;
  dirs)        cmd_dirs ;;
  -h | --help) usage ;;
  *) log_error "Unknown command: $subcmd"; usage; exit 1 ;;
  esac
}

main "$@"
