#!/usr/bin/env bash
# Description: Switch niri keyboard layout (gb/us) or show current layout

set -euo pipefail

usage() {
    echo "Usage: niri-layout [next|prev|gb|us]"
    echo "       niri-layout          # toggle to next layout"
    exit 1
}

action="${1:-next}"

case "$action" in
    next|prev)
        niri msg action switch-layout "$action"
        ;;
    gb|us)
        niri msg action switch-layout "$action"
        ;;
    -h|--help)
        usage
        ;;
    *)
        usage
        ;;
esac
