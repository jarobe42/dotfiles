#!/usr/bin/env bash
# Description: First-run setup for Niri / Wayland desktop

set -Eeuo pipefail
source "$DOTFILES/bin/lib/common.sh"
command_name=$(basename "${BASH_SOURCE[0]}")

usage() {
  cat <<EOF
  $(fmt_key "Usage:") $(fmt_cmd "$command_name") $(fmt_value "[options] <command>")

  First-run setup for the Niri Wayland desktop environment.

$(fmt_key "Commands:")
    setup       Run all first-run setup steps
    validate    Validate the niri config without starting niri
    dirs        Create XDG user directories (Documents, Downloads, etc.)
EOF
}

cmd_validate() {
  fmt_title_underline "Validating niri config"

  if ! command -v niri &>/dev/null; then
    log_warning "niri not installed yet"
    return
  fi

  if niri validate --config "$HOME/.config/niri/config.kdl"; then
    log_success "niri config is valid"
  else
    log_error "niri config has errors — fix before first launch"
    exit 1
  fi
}

cmd_dirs() {
  fmt_title_underline "Creating XDG user directories"

  if command -v xdg-user-dirs-update &>/dev/null; then
    xdg-user-dirs-update
    log_success "XDG user dirs created"
  else
    log_warning "xdg-user-dirs not found — install it first"
  fi
}

cmd_setup() {
  fmt_title_underline "Niri first-run setup"

  cmd_dirs
  cmd_validate

  # Ensure niri session script is available in PATH for login manager
  if [[ -f /usr/share/wayland-sessions/niri.desktop ]]; then
    log_success "niri.desktop session file found"
  else
    log_warning "niri.desktop not found in /usr/share/wayland-sessions/"
    log_info "You may need to launch niri manually or configure your display manager"
  fi

  echo -e
  log_success "Niri setup done"
  log_info ""
  log_info "Manual steps:"
  log_info "  1. Log out and select 'Niri' from your display manager"
  log_info "  2. Or add 'exec niri' to ~/.xinitrc if starting from TTY"
  log_info "  3. Review ~/.config/niri/config.kdl and set your monitor output names"
  log_info "     Run: niri msg outputs  (once inside a niri session)"
}

main() {
  local subcmd="${1:-setup}"
  shift || true

  case "$subcmd" in
  setup)    cmd_setup ;;
  validate) cmd_validate ;;
  dirs)     cmd_dirs ;;
  -h | --help) usage ;;
  *) log_error "Unknown command: $subcmd"; usage; exit 1 ;;
  esac
}

main "$@"
