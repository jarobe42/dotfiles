{
    // Waybar config
    // Reference: https://github.com/Alexays/Waybar/wiki/Configuration
    // Reload: killall -SIGUSR2 waybar

    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,

    "modules-left": ["niri/workspaces", "niri/window"],
    "modules-center": ["clock"],
    "modules-right": ["pulseaudio", "network", "battery", "tray"],

    ////////////////////////////////////////////////////
    // Left modules
    ////////////////////////////////////////////////////

    "niri/workspaces": {
        "format": "{index}"
    },

    "niri/window": {
        "format": "{title}",
        "max-length": 50
    },

    ////////////////////////////////////////////////////
    // Center modules
    ////////////////////////////////////////////////////

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>"
    },

    ////////////////////////////////////////////////////
    // Right modules
    ////////////////////////////////////////////////////

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "on-click": "pavucontrol"
    },

    "network": {
        "format-wifi": "󰤨 {signalStrength}%",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰤭",
        "tooltip-format": "{essid} ({ifname}) {ipaddr}"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-icons": ["󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "tray": {
        "spacing": 8
    }
}
