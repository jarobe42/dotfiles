// Niri config — scrollable tiling Wayland compositor
// Reference: https://github.com/YaLTeR/niri/wiki/Configuration
// Validate without restarting: niri validate
// Reload live: Super+Shift+R  (or: niri msg action reload-config)

////////////////////////////////////////////////////////
// Input
////////////////////////////////////////////////////////

input {
    keyboard {
        xkb {
            layout "gb,us"
            // options "caps:escape"  // remap Caps Lock to Escape
        }
    }

    touchpad {
        tap                    // tap to click
        natural-scroll         // reverse scroll direction
        // dwt                 // disable while typing
    }

    mouse {
        // natural-scroll  // uncomment to enable (default: off)
    }
}

////////////////////////////////////////////////////////
// Outputs (monitors)
// Find your output names: niri msg outputs
// Common: "eDP-1" (laptop), "HDMI-A-1", "DP-1"
////////////////////////////////////////////////////////

// output "eDP-1" {
//     scale 2.0
//     // mode "2560x1600@120.000"
// }

// output "HDMI-A-1" {
//     scale 1.0
//     position x=2560 y=0  // position relative to laptop screen
// }

////////////////////////////////////////////////////////
// Layout
////////////////////////////////////////////////////////

layout {
    // Gap between windows and screen edges
    gaps 8

    // Centre the focused window when it's the only one in the workspace?
    center-focused-column "never"

    // Column width presets — cycle with Super+R (resize mode), or direct binds
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    // Window borders
    focus-ring {
        // width 2
        // active-color "#cba6f7"    // catppuccin mauve
        // inactive-color "#45475a"
    }
}

////////////////////////////////////////////////////////
// Appearance
////////////////////////////////////////////////////////

// prefer-no-csd  // request server-side decorations from apps

////////////////////////////////////////////////////////
// Spawn rules
// Float specific applications automatically
////////////////////////////////////////////////////////

window-rule {
    match app-id="org.gnome.Nautilus"
    open-floating true
}

window-rule {
    match app-id="com.mitchellh.ghostty"
    default-column-width { proportion 0.85; }
}

// window-rule {
//     match app-id="1password"
//     open-floating true
// }

////////////////////////////////////////////////////////
// Key bindings
// Mod = Super (Windows key)
// See: https://github.com/YaLTeR/niri/wiki/Key-Bindings
////////////////////////////////////////////////////////

binds {
    ////////////////////////////////////////////////////
    // Session
    ////////////////////////////////////////////////////

    // Lock screen
    Mod+Ctrl+L { spawn "swaylock"; }

    // Quit niri (shows confirmation)
    Mod+Shift+E { quit; }

    ////////////////////////////////////////////////////
    // Launchers
    ////////////////////////////////////////////////////

    // Terminal
    Mod+Return { spawn "ghostty"; }

    // App launcher (fuzzel)
    Mod+D { spawn "fuzzel"; }

    ////////////////////////////////////////////////////
    // Windows
    ////////////////////////////////////////////////////

    Mod+Q { close-window; }

    // Focus
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+J { focus-window-down; }
    Mod+K { focus-window-up; }

    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Down  { focus-window-down; }
    Mod+Up    { focus-window-up; }

    // Move windows
    Mod+Shift+H { move-column-left; }
    Mod+Shift+L { move-column-right; }
    Mod+Shift+J { move-window-down; }
    Mod+Shift+K { move-window-up; }

    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Shift+Down  { move-window-down; }
    Mod+Shift+Up    { move-window-up; }

    // Resize mode (then use H/J/K/L or arrow keys, Escape to exit)
    Mod+R { switch-preset-column-width; }

    // Fullscreen / float
    Mod+F       { maximize-column; }
    Mod+Shift+F { toggle-window-floating; }

    // Jump to edges
    Mod+Home { focus-column-first; }
    Mod+End  { focus-column-last; }

    ////////////////////////////////////////////////////
    // Workspaces
    ////////////////////////////////////////////////////

    Mod+U { focus-workspace-down; }
    Mod+I { focus-workspace-up; }

    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    ////////////////////////////////////////////////////
    // Screenshots
    // Requires: grim + slurp
    ////////////////////////////////////////////////////

    // Region screenshot → clipboard
    Print { spawn "sh" "-c" "grim -g \"$(slurp)\" - | wl-copy"; }

    // Focused window → clipboard
    Mod+Print { screenshot-window; }

    // Full screen → file in ~/Pictures
    Mod+Shift+Print { screenshot; }

    ////////////////////////////////////////////////////
    // Audio (PipeWire / pactl)
    ////////////////////////////////////////////////////

    XF86AudioRaiseVolume  { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "+5%"; }
    XF86AudioLowerVolume  { spawn "pactl" "set-sink-volume" "@DEFAULT_SINK@" "-5%"; }
    XF86AudioMute         { spawn "pactl" "set-sink-mute" "@DEFAULT_SINK@" "toggle"; }
    XF86AudioMicMute      { spawn "pactl" "set-source-mute" "@DEFAULT_SOURCE@" "toggle"; }

    ////////////////////////////////////////////////////
    // Brightness
    ////////////////////////////////////////////////////

    XF86MonBrightnessUp   { spawn "brightnessctl" "set" "+10%"; }
    XF86MonBrightnessDown { spawn "brightnessctl" "set" "10%-"; }
}

////////////////////////////////////////////////////////
// Autostart
// Programs launched when niri starts
////////////////////////////////////////////////////////

spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "swaybg" "-m" "fill" "-c" "#1e1e2e"  // solid colour until wallpaper is set
// spawn-at-startup "swaybg" "-i" "/path/to/wallpaper.jpg" "-m" "fill"
spawn-at-startup "polkit-gnome-authentication-agent-1"
